<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- Handle HTML files -->
      <add name="html" path="*.html" verb="*" type="System.Web.DefaultHttpHandler, System.Web, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" resourceType="File" preCondition="integratedMode" />

      <!-- Handle Node.js requests -->
      <add name="iisnode" path="app.js" verb="*" modules="iisnode" />

      <!-- Remove WebDAV handler to prevent method conflicts -->
      <remove name="WebDAV" />
    </handlers>
    <iisnode node_env="production" loggingEnabled="true" devErrorsEnabled="true" />

    <modules>
      <!-- Remove WebDAV module to prevent method conflicts -->
      <remove name="WebDAVModule" />
    </modules>

    <!-- Define the node process command line -->
    <!-- <iisnode nodeProcessCommandLine="C:\Program Files\nodejs\node.exe" loggingEnabled="true" logDirectory="iisnode" /> -->

    <!-- Enable directory browsing (if needed) -->
    <directoryBrowse enabled="true" />

    <!-- URL rewriting rules -->
    <rewrite>
      <rules>
        <rule name="nodejs">
          <match url="(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="/app.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Security and request filtering settings -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="iisnode" />
        </hiddenSegments>
        <!-- Allow all verbs to avoid 405 errors -->
        <verbs>
          <add verb="*" allowed="true" />
        </verbs>
      </requestFiltering>
    </security>
        <httpErrors errorMode="Detailed" />
  </system.webServer>
</configuration>
