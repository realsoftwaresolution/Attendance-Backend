{
  "name": "attendance-api-secured",
  "version": "1.0.0",
  "description": "Attendance system API with JWT authentication and MSSQL integration.",
  "main": "index.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "build": "echo \"No build step required\"",
    "lint": "eslint .",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "migrate": "sequelize-cli db:migrate",
    "seed": "sequelize-cli db:seed:all",
    "prettier": "prettier --write .",
    "format": "prettier --check .",
    "deploy": "node app.js",
    "clean": "rimraf node_modules",
    "debug": "node --inspect app.js"
  },
  "keywords": [
    "attendance",
    "nodejs",
    "express",
    "sequelize",
    "mssql",
    "jwt",
    "api"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1",
    "sequelize": "^6.37.5",
    "tedious": "^18.6.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "sequelize-cli": "^6.6.1"
  }
}
